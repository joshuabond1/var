# Copy this file to .env and fill in your values
# The local_agent.py reads this automatically

# Your Railway app URL — no trailing slash
RELAY_URL=https://your-app.railway.app

# A secret string shared between Railway and your laptop
# Generate one with: python -c "import secrets; print(secrets.token_hex(16))"
# Set this SAME value in Railway dashboard > Variables
RELAY_SECRET=change-me-to-a-random-string
